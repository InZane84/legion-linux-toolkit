#!/usr/bin/env xdg-open
[Desktop Entry]
Type=Application
Name=Legion Toolkit
Comment=Lenovo Legion power management tray
Exec=/usr/lib/legion-toolkit/legion-tray.py
Icon=battery-good
Categories=System;HardwareSettings;
Keywords=legion;power;thermal;lenovo;
StartupNotify=false
# Autostart on KDE Plasma login
X-KDE-autostart-condition=legion-toolkit
